@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-header">
    <h1>Control Panel – @(ViewData["InstanceName"] ?? "localhost")</h1>
</div>

<div class="dashboard-grid">
    <!-- Card 1: Login -->
    <div class="dashboard-card">
        <div class="card-title">Login</div>
        <div class="card-description">Simulate user login</div>
        <button class="card-btn" onclick="handleLogin(this)">Start Session</button>
        <div class="card-result"></div>
    </div>

    <div class="dashboard-card">
        <div class="card-title">Error</div>
        <div class="card-description">Generate monitored backend exception</div>
        <button class="card-btn" onclick="handleError(this)">Trigger Error</button>
        <div class="card-result"></div>
    </div>

    <!-- Cards 2–16: Placeholders -->
    <div class="dashboard-card">
        <div class="card-title">Reports</div>
        <div class="card-description">Generate system reports</div>
        <button class="card-btn" disabled>Run Report</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Users</div>
        <div class="card-description">Manage user accounts</div>
        <button class="card-btn" disabled>Manage</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Settings</div>
        <div class="card-description">Configure system settings</div>
        <button class="card-btn" disabled>Configure</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Analytics</div>
        <div class="card-description">View usage analytics</div>
        <button class="card-btn" disabled>View</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Notifications</div>
        <div class="card-description">Send push notifications</div>
        <button class="card-btn" disabled>Send</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Backup</div>
        <div class="card-description">Backup system data</div>
        <button class="card-btn" disabled>Backup</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Logs</div>
        <div class="card-description">View system logs</div>
        <button class="card-btn" disabled>View Logs</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Permissions</div>
        <div class="card-description">Control access permissions</div>
        <button class="card-btn" disabled>Manage</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Database</div>
        <div class="card-description">Manage database connections</div>
        <button class="card-btn" disabled>Connect</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">API Keys</div>
        <div class="card-description">Generate or revoke API keys</div>
        <button class="card-btn" disabled>Generate</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Scheduler</div>
        <div class="card-description">Schedule automated tasks</div>
        <button class="card-btn" disabled>Schedule</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Audit</div>
        <div class="card-description">Review audit trail</div>
        <button class="card-btn" disabled>Audit</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Monitor</div>
        <div class="card-description">Monitor system health</div>
        <button class="card-btn" disabled>Monitor</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Support</div>
        <div class="card-description">Open a support ticket</div>
        <button class="card-btn" disabled>Contact</button>
        <div class="card-result"></div>
    </div>
    <div class="dashboard-card">
        <div class="card-title">Logout</div>
        <div class="card-description">End the current session</div>
        <button class="card-btn" disabled>End Session</button>
        <div class="card-result"></div>
    </div>
</div>

@section Scripts {
@Html.AntiForgeryToken()
<script>
    function handleLogin(btn) {
        btn.disabled = true;
        btn.textContent = 'Loading…';
        var card = btn.closest('.dashboard-card');
        var resultEl = card.querySelector('.card-result');
        resultEl.className = 'card-result';

        fetch('/Home/Login', {
            method: 'POST',
            headers: { 'RequestVerificationToken': getAntiForgeryToken() }
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            resultEl.textContent = data.fullName + ' has logged in';
            resultEl.classList.add('result-success');
        })
        .catch(function() {
            resultEl.textContent = 'Login failed. Please try again.';
            resultEl.classList.add('result-error');
        })
        .finally(function() {
            btn.disabled = false;
            btn.textContent = 'Start Session';
        });
    }

    function handleError(btn) {
        btn.disabled = true;
        btn.textContent = 'Loading…';
        var card = btn.closest('.dashboard-card');
        var resultEl = card.querySelector('.card-result');
        resultEl.className = 'card-result';

        fetch('/Home/TriggerError', {
            method: 'POST',
            headers: { 'RequestVerificationToken': getAntiForgeryToken() }
        })
        .then(function(response) {
            if (!response.ok) {
                throw new Error('Server error');
            }
            return response.text();
        })
        .then(function() {
            resultEl.textContent = 'Error endpoint returned successfully.';
            resultEl.classList.add('result-success');
        })
        .catch(function() {
            resultEl.textContent = 'Error generated and sent to backend telemetry.';
            resultEl.classList.add('result-error');
        })
        .finally(function() {
            btn.disabled = false;
            btn.textContent = 'Trigger Error';
        });
    }

    function getAntiForgeryToken() {
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenEl ? tokenEl.value : '';
    }
</script>
}
